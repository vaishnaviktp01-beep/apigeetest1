<ProxyEndpoint name="default">
<Description>Default Proxy Endpoint</Description>
<HTTPProxyConnection>
<BasePath>/hello</BasePath>
</HTTPProxyConnection>
<FaultRules/>
<PreFlow name="PreFlow">
<Request/>
<Response/>
</PreFlow>
<PostFlow name="PostFlow">
<Request/>
<Response/>
</PostFlow>
<Flows>
<Flow name="GetHello">
<Description>Return a hello response</Description>
<Request/>
<Response>
<Step>
<Name>AM-SetResponse</Name>
</Step>
</Response>
<Condition>(proxy.pathsuffix MatchesPath "/") and (request.verb = "GET")</Condition>
</Flow>
</Flows>
<RouteRule name="NoRoute"/>
</ProxyEndpoint>
